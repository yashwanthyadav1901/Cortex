# Supabase Postgres — direct connection for local dev (port 5432).
# If direct doesn't connect (IPv6-only), use the session pooler string instead.
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase project URL — used to verify login tokens via the JWKS endpoint
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Only needed if your project still uses the legacy shared JWT secret (HS256).
# Projects on the newer JWT signing keys (ES256) can leave this empty.
SUPABASE_JWT_SECRET=

# Only this email is allowed through auth (single-user app)
ALLOWED_EMAIL=yashwanth@apsona.com

# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:3000

# IANA timezone anchoring streak/activity day boundaries (not the server's clock)
TIMEZONE=Asia/Kolkata

# ---- AI topic chat ----
# Which provider answers topic chat: "nvidia" (dev, free) | "anthropic" (prod)
LLM_PROVIDER=nvidia
# Free key from https://build.nvidia.com (starts with nvapi-)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
# Only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
